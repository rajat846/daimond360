# ============================================================
#  Diamond 360 Pipeline — Environment Variables
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/diamond360

# --- Redis (BullMQ) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# --- GraphQL API ---
GRAPHQL_URL=https://integrations.nivoda.net/graphql-loupe360

# --- Processing ---
# Max concurrent retries per row
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_MS=2000

# --- Temp storage ---
TEMP_DIR=/tmp/diamond360
